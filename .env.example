# Bare metal host for integration testing
BM_HOST=           # IP or hostname (e.g. 203.0.113.10)
BM_USER=root       # SSH user
BM_SSH_KEY=        # Path to SSH private key (e.g. ~/.ssh/id_ed25519)
BM_PASSWORD=       # SSH password (if not using key auth)

# API keys for demo agent
OPENAI_API_KEY=    # For running the LLM-driven demo agent
